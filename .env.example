# ============================================
# DramaKu - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# --------------------------------------------
# TMDB (The Movie Database) API
# --------------------------------------------
# Get your free API Read Access Token at:
# https://www.themoviedb.org/settings/api
# Use the "API Read Access Token (v4 auth)" — it's a long JWT string
TMDB_ACCESS_TOKEN=your_tmdb_read_access_token_here

# Your TMDB v3 API Key (optional, used as fallback)
TMDB_API_KEY=your_tmdb_api_key_here

# --------------------------------------------
# Site Configuration
# --------------------------------------------
NEXT_PUBLIC_SITE_NAME=DramaKu
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --------------------------------------------
# Streaming Embed (vidsrc.to — free & public)
# --------------------------------------------
# Base URL for video embeds (no key required)
# TV:    https://vidsrc.to/embed/tv/{tmdb_id}/{season}/{episode}
# Movie: https://vidsrc.to/embed/movie/{tmdb_id}
NEXT_PUBLIC_EMBED_BASE_URL=https://vidsrc.icu/embed
NEXT_PUBLIC_EMBED_BASE_URL_SECONDARY=https://vidsrc.to/embed
